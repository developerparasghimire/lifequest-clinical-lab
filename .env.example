# ---- Database (Neon Postgres) ----
# Get the pooled connection string from https://console.neon.tech
# Example: postgresql://USER:PASSWORD@ep-xyz-pooler.aws.neon.tech/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ---- NextAuth v5 ----
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
# Vercel auto-populates this; set manually for local dev only
NEXTAUTH_URL="http://localhost:3000"

# ---- Public site URL (used in sitemap.ts, robots.ts, OG tags) ----
NEXT_PUBLIC_SITE_URL="https://lifequestclinicallab.com.np"

# ---- Google Search Console verification (optional) ----
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""

# ---- WhatsApp floating button ----
NEXT_PUBLIC_WHATSAPP_NUMBER="9779802302471"

# ---- SMTP (optional — appointment confirmation & contact notifications) ----
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Life Quest Clinical Lab <noreply@example.com>"
ADMIN_EMAIL=""
